# App Config
FLASK_APP=run.py
FLASK_ENV=development
DEBUG=true
PORT=5000
LOG_LEVEL=INFO

# Security
SECRET_KEY=your-secret-key-here
JWT_SECRET_KEY=your-jwt-secret-key-here

# Database
# For SQLite: sqlite:///queue.db
# For PostgreSQL: postgresql://user:password@localhost:5432/queue_db
DATABASE_URL=sqlite:///queue.db
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_RECYCLE=1800

# CORS
ALLOWED_ORIGINS=*

# ML Models
WAIT_TIME_MODEL_PATH=app/ai/wait_time_model.pkl
MODEL_VERSION=1.0.0
